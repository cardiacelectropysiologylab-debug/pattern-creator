def _rect_inside_circle_fraction(rx, ry, cx, cy, half_length, half_width, radius, samples=5):
    """Estimate fraction of rectangle that lies inside a circle via uniform sampling."""
    r2 = radius * radius
    count = 0
    for i in range(samples):
        sx = rx - half_length + (2 * half_length * i / (samples - 1)) if samples > 1 else rx
        for j in range(samples):
            sy = ry - half_width + (2 * half_width * j / (samples - 1)) if samples > 1 else ry
            if (sx - cx) ** 2 + (sy - cy) ** 2 <= r2:
                count += 1
    return count / (samples * samples)


def _render_pdf_first_page_to_image(pdf_path, scale=4.0):
    """Render first page of a PDF to a PIL image.

    Tries pypdfium2 first, then PyMuPDF (fitz) as fallback.
    """
    try:
        import pypdfium2 as pdfium
        doc = pdfium.PdfDocument(pdf_path)
        if len(doc) == 0:
            raise ValueError("PDF has no pages")
        page = doc[0]
        bitmap = page.render(scale=scale)
        image = bitmap.to_pil().convert("RGB")
        page.close()
        doc.close()
        return image
    except Exception:
        pass

    try:
        import fitz
        doc = fitz.open(pdf_path)
        if doc.page_count == 0:
            raise ValueError("PDF has no pages")
        page = doc.load_page(0)
        mat = fitz.Matrix(scale, scale)
        pix = page.get_pixmap(matrix=mat, alpha=False)
        image = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
        doc.close()
        return image
    except Exception as ex:
        raise RuntimeError(
            "Could not read PDF page. Install pypdfium2 (preferred) or PyMuPDF."
        ) from ex


def _estimate_rectangles_and_spacing_from_circle(img_l, cx, cy, radius, threshold):
    """Estimate rectangle length/width and spacing from a binarized circle region.

    Returns measurements in pixels as a dict, or None if detection is insufficient.
    """
    def _cluster_axis(values, tolerance):
        if not values:
            return []
        values = sorted(values)
        groups = [[values[0]]]
        for value in values[1:]:
            if abs(value - statistics.mean(groups[-1])) <= tolerance:
                groups[-1].append(value)
            else:
                groups.append([value])
        return groups

    def _robust_median(samples):
        if not samples:
            return None
        samples = sorted(samples)
        if len(samples) < 5:
            return statistics.median(samples)
        q1 = samples[len(samples) // 4]
        q3 = samples[(3 * len(samples)) // 4]
        iqr = max(1e-9, q3 - q1)
        low = q1 - 1.5 * iqr
        high = q3 + 1.5 * iqr
        trimmed = [value for value in samples if low <= value <= high]
        return statistics.median(trimmed if trimmed else samples)

    def _detect_once(local_threshold):
        width, height = img_l.size
        pixels = img_l.load()

        xmin = max(0, int(cx - radius - 1))
        xmax = min(width - 1, int(cx + radius + 1))
        ymin = max(0, int(cy - radius - 1))
        ymax = min(height - 1, int(cy + radius + 1))

        bw_w = xmax - xmin + 1
        bw_h = ymax - ymin + 1
        if bw_w < 10 or bw_h < 10:
            return None

        size = bw_w * bw_h
        black = bytearray(size)
        visited = bytearray(size)
        r2 = radius * radius

        for local_y in range(bw_h):
            y = ymin + local_y
            dy = y - cy
            row_base = local_y * bw_w
            for local_x in range(bw_w):
                x = xmin + local_x
                dx = x - cx
                if dx * dx + dy * dy <= r2 and pixels[x, y] <= local_threshold:
                    black[row_base + local_x] = 1

        components = []
        min_area = max(6, int((radius * 0.01) ** 2))
        max_area = int(max(400, (math.pi * radius * radius) * 0.08))

        for idx in range(size):
            if not black[idx] or visited[idx]:
                continue

            stack = [idx]
            visited[idx] = 1

            n = 0
            sum_x = 0.0
            sum_y = 0.0
            sum_xx = 0.0
            sum_yy = 0.0
            sum_xy = 0.0

            while stack:
                cur = stack.pop()
                cy_local = cur // bw_w
                cx_local = cur - cy_local * bw_w

                gx = xmin + cx_local
                gy = ymin + cy_local

                n += 1
                sum_x += gx
                sum_y += gy
                sum_xx += gx * gx
                sum_yy += gy * gy
                sum_xy += gx * gy

                for ny in (cy_local - 1, cy_local, cy_local + 1):
                    if ny < 0 or ny >= bw_h:
                        continue
                    for nx in (cx_local - 1, cx_local, cx_local + 1):
                        if nx < 0 or nx >= bw_w or (nx == cx_local and ny == cy_local):
                            continue
                        nxt = ny * bw_w + nx
                        if black[nxt] and not visited[nxt]:
                            visited[nxt] = 1
                            stack.append(nxt)

            if n < min_area or n > max_area:
                continue

            mean_x = sum_x / n
            mean_y = sum_y / n
            var_x = max(0.0, (sum_xx / n) - (mean_x * mean_x))
            var_y = max(0.0, (sum_yy / n) - (mean_y * mean_y))
            cov_xy = (sum_xy / n) - (mean_x * mean_y)

            trace = var_x + var_y
            det = var_x * var_y - cov_xy * cov_xy
            disc = max(0.0, (trace * trace * 0.25) - det)
            root_disc = math.sqrt(disc)
            eig1 = max(0.0, trace * 0.5 + root_disc)
            eig2 = max(0.0, trace * 0.5 - root_disc)

            length_px = math.sqrt(12.0 * eig1) if eig1 > 0 else 0.0
            width_px = math.sqrt(12.0 * eig2) if eig2 > 0 else 0.0
            if length_px < width_px:
                length_px, width_px = width_px, length_px

            if length_px < 2.0 or width_px < 1.0:
                continue

            theta = 0.5 * math.atan2(2.0 * cov_xy, (var_x - var_y))

            components.append({
                "center_x": mean_x,
                "center_y": mean_y,
                "length_px": length_px,
                "width_px": width_px,
                "theta": theta,
            })

        if len(components) < 5:
            return None

        lengths = [comp["length_px"] for comp in components if comp["length_px"] > 0]
        widths = [comp["width_px"] for comp in components if comp["width_px"] > 0]
        if len(lengths) < 4 or len(widths) < 4:
            return None

        length_est = _robust_median(lengths)
        width_est = _robust_median(widths)
        if not length_est or not width_est or length_est <= 0 or width_est <= 0:
            return None

        angles = [comp["theta"] for comp in components]
        sin2 = statistics.mean(math.sin(2.0 * angle) for angle in angles)
        cos2 = statistics.mean(math.cos(2.0 * angle) for angle in angles)
        theta = 0.5 * math.atan2(sin2, cos2)

        u_x = math.cos(theta)
        u_y = math.sin(theta)
        v_x = -u_y
        v_y = u_x

        centers = []
        for comp in components:
            x = comp["center_x"]
            y = comp["center_y"]
            pu = x * u_x + y * u_y
            pv = x * v_x + y * v_y
            centers.append((pu, pv))

        row_tol = max(2.0, width_est * 0.9)
        col_tol = max(2.0, length_est * 0.9)

        rows = _cluster_axis([value[1] for value in centers], row_tol)
        cols = _cluster_axis([value[0] for value in centers], col_tol)
        row_centers = [statistics.mean(group) for group in rows]
        col_centers = [statistics.mean(group) for group in cols]

        along_periods = []
        across_periods = []

        for row_center in row_centers:
            row_values = sorted(
                value[0] for value in centers
                if abs(value[1] - row_center) <= row_tol
            )
            for i in range(1, len(row_values)):
                delta = row_values[i] - row_values[i - 1]
                if delta > 1.0:
                    along_periods.append(delta)

        for col_center in col_centers:
            col_values = sorted(
                value[1] for value in centers
                if abs(value[0] - col_center) <= col_tol
            )
            for i in range(1, len(col_values)):
                delta = col_values[i] - col_values[i - 1]
                if delta > 1.0:
                    across_periods.append(delta)

        period_along = _robust_median(along_periods)
        period_across = _robust_median(across_periods)
        if period_along is None or period_across is None:
            return None

        if period_along <= 0 or period_across <= 0:
            return None

        spacing_along = max(0.0, period_along - length_est)
        spacing_across = max(0.0, period_across - width_est)

        return {
            "rect_length_px": length_est,
            "rect_width_px": width_est,
            "spacing_along_px": spacing_along,
            "spacing_across_px": spacing_across,
            "period_along_px": period_along,
            "period_across_px": period_across,
            "components": len(components),
        }

    candidates = []
    for delta in (0, 16, -16, 28, -28, 40, -40):
        t = max(0, min(255, int(threshold + delta)))
        if t not in candidates:
            candidates.append(t)

    best = None
    for local_threshold in candidates:
        detected = _detect_once(local_threshold)
        if detected is None:
            continue
        if best is None or detected["components"] > best["components"]:
            best = detected

    return best


# ========== INTERSTITIAL PATTERN (RECTANGULAR MESH) ==========
def add_interstitial(c, cx, cy, radius_pt, coverage, rect_length_mm, rect_width_mm, 
                     spacing_along_mm, spacing_across_mm, angle_deg=0, indentation=0.0):
    """Add rectangular mesh pattern (interstitial fibrosis)
    
    Creates a grid of rectangles with:
    - Fixed rectangle dimensions (length x width)
    - Fixed spacing along and across rectangles
    - Coverage controlled by rectangle size and spacing
    - Optional indentation of alternating rows
    """
    if coverage <= 0:
        return
    
    rect_length_pt = rect_length_mm * mm
    rect_width_pt = rect_width_mm * mm
    spacing_along_pt = spacing_along_mm * mm
    spacing_across_pt = spacing_across_mm * mm
    
    # Also remove unused fill_fraction variable in PDF path
    # Use a single fixed grid; coverage controls occupancy of grid slots
    # (fill_fraction replaced by area-accumulation below)

    # Create grid of rectangles
    period_along = rect_length_pt + spacing_along_pt
    period_across = rect_width_pt + spacing_across_pt
    
    # Calculate how many rectangles fit
    diag = radius_pt * 3
    num_along = int(math.ceil(diag * 2 / period_along)) + 4
    num_across = int(math.ceil(diag * 2 / period_across)) + 4
    
    # Center the grid
    start_along = -num_along * period_along / 2.0
    start_across = -num_across * period_across / 2.0
    
    c.saveState()
    c.translate(cx, cy)
    c.rotate(angle_deg)
    c.translate(-cx, -cy)
    c.setFillColor(colors.black)

    candidates = []
    for i in range(num_along):
        for j in range(num_across):
            x = cx + start_along + i * period_along
            y = cy + start_across + j * period_across

            # Apply indentation to every other row
            if j % 2 == 1:
                x += period_along * (indentation / 100.0)

            dist = math.sqrt((x - cx) ** 2 + (y - cy) ** 2)
            if dist <= radius_pt + rect_length_pt:
                candidates.append((x, y))

    if not candidates:
        c.restoreState()
        return

    candidates.sort(key=lambda pos: ((pos[0] - cx) ** 2 + (pos[1] - cy) ** 2))

    # Accumulate weighted coverage until target is reached so achieved == target
    circle_area = math.pi * radius_pt * radius_pt
    target_area = coverage * circle_area
    rect_area = rect_length_pt * rect_width_pt
    half_l = rect_length_pt / 2.0
    half_w = rect_width_pt / 2.0
    accumulated = 0.0
    draw_list = []
    for x, y in candidates:
        if accumulated >= target_area:
            break
        frac = _rect_inside_circle_fraction(x, y, cx, cy, half_l, half_w, radius_pt)
        accumulated += frac * rect_area
        draw_list.append((x, y))

    for x, y in draw_list:
        c.rect(x - half_l, y - half_w,
               rect_length_pt, rect_width_pt, stroke=0, fill=1)
    
    c.restoreState()

def add_interstitial_preview(draw, cx, cy, radius_px, coverage, rect_length_px, rect_width_px,
                             spacing_along_px, spacing_across_px, angle_deg, indentation=0.0):
    """Preview for interstitial rectangular mesh pattern"""
    if coverage <= 0:
        return
    
    spacing_along_px = max(1.0, spacing_along_px)
    spacing_across_px = max(1.0, spacing_across_px)
    
    # Use a single fixed grid; coverage controls occupancy of grid slots
    # (fill_fraction replaced by area-accumulation below)

    # Create grid
    period_along = rect_length_px + spacing_along_px
    period_across = rect_width_px + spacing_across_px
    
    diag = radius_px * 3
    num_along = int(math.ceil(diag * 2 / period_along)) + 4
    num_across = int(math.ceil(diag * 2 / period_across)) + 4
    
    start_along = -num_along * period_along / 2.0
    start_across = -num_across * period_across / 2.0
    
    angle = math.radians(angle_deg)
    cos_a = math.cos(angle)
    sin_a = math.sin(angle)

    candidates = []
    for i in range(num_along):
        for j in range(num_across):
            x = start_along + i * period_along
            y = start_across + j * period_across

            # Apply indentation to every other row
            if j % 2 == 1:
                x += period_along * (indentation / 100.0)

            # Rotate around center
            x_rot = cx + x * cos_a - y * sin_a
            y_rot = cy + x * sin_a + y * cos_a

            dist = math.sqrt((x_rot - cx) ** 2 + (y_rot - cy) ** 2)
            if dist <= radius_px + rect_length_px:
                candidates.append((x_rot, y_rot))

    if not candidates:
        return

    candidates.sort(key=lambda pos: ((pos[0] - cx) ** 2 + (pos[1] - cy) ** 2))

    # Accumulate weighted coverage until target is reached so achieved == target
    circle_area = math.pi * radius_px * radius_px
    target_area = coverage * circle_area
    rect_area = rect_length_px * rect_width_px
    half_length = rect_length_px / 2.0
    half_width = rect_width_px / 2.0
    accumulated = 0.0
    draw_list = []
    for x_rot, y_rot in candidates:
        if accumulated >= target_area:
            break
        frac = _rect_inside_circle_fraction(x_rot, y_rot, cx, cy, half_length, half_width, radius_px)
        accumulated += frac * rect_area
        draw_list.append((x_rot, y_rot))

    corners = [
        (-half_length, -half_width),
        (half_length, -half_width),
        (half_length, half_width),
        (-half_length, half_width)
    ]

    for x_rot, y_rot in draw_list:
        points = []
        for dx, dy in corners:
            px = x_rot + dx * cos_a - dy * sin_a
            py = y_rot + dx * sin_a + dy * cos_a
            points.append((px, py))
        draw.polygon(points, fill=0, outline=0)

def _estimate_diffuse_coverage(rectangles, radius_units, rect_length_units, rect_width_units, mask_size=700):
    """Estimate diffuse coverage fraction inside circular region using rasterization"""
    if radius_units <= 0:
        return 0.0

    mask = Image.new("L", (mask_size, mask_size), 0)
    draw_mask = ImageDraw.Draw(mask)
    tissue = Image.new("L", (mask_size, mask_size), 0)
    draw_tissue = ImageDraw.Draw(tissue)

    cx = cy = mask_size / 2.0
    scale = (mask_size * 0.45) / radius_units
    r_px = radius_units * scale

    draw_tissue.ellipse((cx - r_px, cy - r_px, cx + r_px, cy + r_px), fill=255)

    half_length = rect_length_units / 2.0
    half_width = rect_width_units / 2.0

    for x_u, y_u, angle_deg in rectangles:
        angle_rad = math.radians(angle_deg)
        cos_a = math.cos(angle_rad)
        sin_a = math.sin(angle_rad)

        corners = [
            (-half_length, -half_width),
            (half_length, -half_width),
            (half_length, half_width),
            (-half_length, half_width),
        ]

        points = []
        for dx, dy in corners:
            rx = dx * cos_a - dy * sin_a
            ry = dx * sin_a + dy * cos_a
            points.append((cx + (x_u + rx) * scale, cy + (y_u + ry) * scale))

        draw_mask.polygon(points, fill=255, outline=255)

    tissue_data = tissue.tobytes()
    mask_data = mask.tobytes()
    tissue_pixels = 0
    covered_pixels = 0
    for i in range(len(tissue_data)):
        if tissue_data[i] > 0:
            tissue_pixels += 1
            if mask_data[i] > 0:
                covered_pixels += 1

    return (covered_pixels / tissue_pixels) if tissue_pixels > 0 else 0.0

def generate_diffuse_layout(radius_units, target_coverage, rect_length_units, rect_width_units, randomness, max_rects=30000):
    """Generate diffuse rectangle layout that matches target coverage"""
    if target_coverage <= 0 or radius_units <= 0 or rect_length_units <= 0 or rect_width_units <= 0:
        return []

    target = max(0.0, min(0.99, target_coverage))
    area_circle = math.pi * radius_units ** 2
    area_rect = rect_length_units * rect_width_units
    if area_rect <= 0:
        return []

    expected_count = max(1, int((target * area_circle) / area_rect))
    rectangles = []
    coverage_now = 0.0
    batch = max(20, min(500, expected_count // 4 if expected_count > 0 else 20))

    while coverage_now < target and len(rectangles) < max_rects:
        to_add = min(batch, max_rects - len(rectangles))
        for _ in range(to_add):
            angle = random.uniform(0, 2 * math.pi)
            r_factor = random.uniform(0, 1) ** 0.5
            r = radius_units * r_factor

            px = r * math.cos(angle)
            py = r * math.sin(angle)

            rect_angle = random.uniform(0, 180)
            scatter = randomness * rect_length_units
            px += random.uniform(-scatter, scatter)
            py += random.uniform(-scatter, scatter)

            rectangles.append((px, py, rect_angle))

        coverage_now = _estimate_diffuse_coverage(
            rectangles,
            radius_units,
            rect_length_units,
            rect_width_units,
        )

        remaining = max(0.0, target - coverage_now)
        est_more = int((remaining * area_circle) / area_rect * 1.5) + 10
        batch = max(10, min(800, est_more))

    return rectangles

# ========== PATCHY PATTERN (IRREGULAR ISLANDS) ==========
def add_patchy(c, cx, cy, radius_pt, coverage, island_size_mm, num_islands, density=1.0):
    """Add patchy pattern with irregular island shapes
    
    Based on research: Creates fibrosis as distinct islands/patches with:
    - Irregular, organic island boundaries (using Fourier harmonics)
    - Random distribution of islands within tissue
    - Variable island sizes based on density parameter
    - Realistic fibrotic remodeling appearance
    """
    if coverage <= 0 or num_islands <= 0:
        return
    
    c.setFillColor(colors.black)
    
    # Calculate island size based on desired coverage
    area_total = math.pi * radius_pt ** 2
    area_per_island = (coverage * area_total) / num_islands
    base_radius_pt = math.sqrt(area_per_island / math.pi)
    
    # Generate islands
    for _ in range(int(num_islands)):
        # Random position uniformly distributed throughout circle area
        angle = random.uniform(0, 2 * math.pi)
        r_factor = random.uniform(0, 1) ** 0.5  # Square root for uniform area distribution
        r = radius_pt * r_factor
        island_cx = cx + r * math.cos(angle)
        island_cy = cy + r * math.sin(angle)
        
        # Variable island size (independent of density)
        size_variation = random.uniform(0.6, 1.4)
        island_radius_pt = base_radius_pt * size_variation
        
        # Create irregular island boundary using Fourier harmonics
        # This creates organic, realistic fibrotic island shapes
        n_points = 32  # Number of points to define the boundary
        points = []
        
        # Fourier harmonics for realistic irregularity
        num_harmonics = 4
        amplitudes = [random.uniform(0.15, 0.4) for _ in range(num_harmonics)]
        phases = [random.uniform(0, 2 * math.pi) for _ in range(num_harmonics)]
        
        for i in range(n_points):
            angle_point = (2 * math.pi * i) / n_points
            
            # Calculate radial variation using Fourier series
            r_variation = 0
            for h in range(num_harmonics):
                freq = h + 1
                r_variation += amplitudes[h] * math.sin(freq * angle_point + phases[h])
            r_variation = r_variation / num_harmonics
            
            # Apply variation to radius (creates wavy boundary)
            r_local = island_radius_pt * (1.0 + 0.6 * r_variation)
            x_local = r_local * math.cos(angle_point)
            y_local = r_local * math.sin(angle_point)
            
            points.append((island_cx + x_local, island_cy + y_local))
        
        # Draw the irregular island
        if len(points) > 0:
            p = c.beginPath()
            p.moveTo(points[0][0], points[0][1])
            for x, y in points[1:]:
                p.lineTo(x, y)
            p.close()
            c.drawPath(p, stroke=0, fill=1)

